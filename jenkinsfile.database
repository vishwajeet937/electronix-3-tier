pipeline{
    agent {label 'electronix'}

    stages{
        stage('Create Database'){
        steps{
            sh 'python3 scripts/create_db.py'
        }
        }
    }
    post{
        success{
            echo 'Database Creation Successfully‚úÖ'
        }
        failure{
            echo ' Database Failes‚ùå'
        }
    }
}
